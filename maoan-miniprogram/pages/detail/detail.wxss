.big{ height:420rpx; background:#eef6f1; display:flex; align-items:center; justify-content:center; font-size:240rpx; }
.d-name{ font-size:40rpx; font-weight:800; margin:14rpx 0 6rpx; }
.d-meta{ color:#6b7770; font-size:26rpx; margin-bottom:24rpx; }

.ing{ border:2rpx solid #e6e0d6; border-radius:20rpx; overflow:hidden; margin-bottom:20rpx; }
.ing-h{ background:#2f7d5b; color:#fff; padding:18rpx 24rpx; font-weight:700; font-size:26rpx; }
.ing-row{ display:flex; justify-content:space-between; padding:18rpx 24rpx; border-bottom:2rpx solid #e6e0d6; font-size:26rpx; }
.ing-v{ font-weight:700; color:#235f45; }
.report{ font-size:24rpx; color:#6b7770; margin-bottom:32rpx; }
.report .link{ color:#2f7d5b; font-weight:600; }

.cmp-title{ font-size:30rpx; font-weight:800; margin-bottom:18rpx; }
.cmp{ display:flex; justify-content:space-between; align-items:center; background:#fff; border:2rpx solid #e6e0d6; border-radius:20rpx; padding:24rpx; margin-bottom:18rpx; }
.cmp-low{ border-color:#2f7d5b; background:#eef6f1; }
.cmp-name{ font-size:30rpx; font-weight:700; }
.low-badge{ background:#2f7d5b; color:#fff; font-size:20rpx; padding:2rpx 12rpx; border-radius:20rpx; margin-left:12rpx; }
.cmp-type{ font-size:22rpx; color:#6b7770; margin-top:6rpx; }
.cmp-r{ text-align:right; }
.cmp-price{ color:#e8a33d; font-weight:800; font-size:36rpx; }
.cmp-go{ font-size:24rpx; color:#2f7d5b; }
.note{ font-size:22rpx; color:#6b7770; margin-top:16rpx; line-height:1.6; }
