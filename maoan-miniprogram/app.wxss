/* 全局样式 · 毛安 PawSure */
page{
  --green:#2f7d5b; --green-d:#235f45; --cream:#faf6ef; --ink:#23302a;
  --gray:#6b7770; --line:#e6e0d6; --amber:#e8a33d; --soft:#eef6f1;
  background:var(--cream); color:var(--ink);
  font-family:-apple-system,"PingFang SC",sans-serif;
}
.wrap{ padding:0 24rpx; }
.banner{ background:#e8a33d; color:#fff; font-size:22rpx; text-align:center; padding:12rpx; font-weight:600; }

.btn{ display:inline-block; padding:20rpx 40rpx; border-radius:48rpx; font-weight:700; font-size:28rpx; border:none; line-height:1.2; }
.btn-amber{ background:#e8a33d; color:#fff; }
.btn-green{ background:#2f7d5b; color:#fff; }
.btn-ghost{ background:rgba(255,255,255,.15); color:#fff; border:2rpx solid rgba(255,255,255,.5); }

.sec{ padding:40rpx 24rpx; }
.sec-title{ font-size:40rpx; font-weight:800; margin-bottom:8rpx; }
.sec-sub{ color:#6b7770; font-size:26rpx; margin-bottom:28rpx; }

.tag{ display:inline-block; background:#eef6f1; color:#235f45; font-size:22rpx; font-weight:700; padding:4rpx 16rpx; border-radius:32rpx; }

/* 商品卡片 */
.card{ background:#fff; border:2rpx solid #e6e0d6; border-radius:28rpx; overflow:hidden; margin-bottom:24rpx; }
.card .thumb{ height:240rpx; background:#eef6f1; display:flex; align-items:center; justify-content:center; font-size:120rpx; }
.card .body{ padding:24rpx; }
.card .name{ font-weight:700; font-size:30rpx; margin:10rpx 0 4rpx; }
.card .desc{ font-size:24rpx; color:#6b7770; margin-bottom:16rpx; }
.card .foot{ display:flex; align-items:center; justify-content:space-between; }
.price{ color:#e8a33d; font-weight:800; font-size:34rpx; }
.price .old{ color:#6b7770; font-weight:400; font-size:22rpx; text-decoration:line-through; margin-left:8rpx; }
.lowtag{ font-size:20rpx; color:#2f7d5b; }
